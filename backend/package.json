{
  "name": "TripWay",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend API for TripWay — Agentic AI Travel Planner",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/index.ts",
    "build": "tsc && node scripts/copy-data.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test-agent": "tsx src/testAgent.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@langchain/core": "^0.3.30",
    "@langchain/langgraph": "^0.2.37",
    "@langchain/openai": "^0.3.14",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.7.2",
    "typescript": "^5.7.0"
  },
  "private": true,
  "license": "UNLICENSED"
}
