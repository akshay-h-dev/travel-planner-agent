# ============================================
# TripWay — Backend Environment
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================

# Server
PORT=5000
NODE_ENV=development

# ── LLM ────────────────────────────────────────────────────
# Groq is used for llama-3.3-70b-versatile (primary LLM)
# Get a free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here   # optional

# ── Travel Data Provider APIs ───────────────────────────────

# OpenTripMap — tourist attractions & places of interest
# Free tier: 5 000 requests / day
# Sign up: https://opentripmap.io/product
OPENTRIPMAP_API_KEY=your_opentripmap_api_key_here

# Amadeus for Developers — flight search
# Free tier (test env): 2 000 calls / month
# Sign up: https://developers.amadeus.com/register
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here
# Use sandbox (test) by default; switch to prod URL when going live:
AMADEUS_BASE_URL=https://test.api.amadeus.com
# AMADEUS_BASE_URL=https://api.amadeus.com  # production

# ── Security ────────────────────────────────────────────────
# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
